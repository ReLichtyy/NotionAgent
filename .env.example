# Lab Sync - Environment Variables Template
# Completa estas variables con tus propias credenciales

# (Obligatorio) Token de integración de Notion (Internal Integration Token)
NOTION_API_KEY=your_notion_integration_token_here

# (Obligatorio) Token de la API de OpenAI (para GPT-4o-mini)
OPENAI_API_KEY=your_openai_api_key_here

# --- Opcionales ---
# Profundidad máxima de rastreo (Default: 3)
# NOTION_MAX_DEPTH=3

# ID de la página raíz de Notion (Si está vacío, busca en todo el workspace accesible)
# NOTION_ROOT_PAGE_ID=

# Fragmentos de contexto recuperados por consulta (Default: 4)
# NOTION_SEARCH_TOP_K=4
